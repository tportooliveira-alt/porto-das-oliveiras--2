# ============================================================
# Porto das Oliveiras — Variáveis de ambiente (Next.js)
# ============================================================
#
# Copie este arquivo para .env.local e preencha os valores.
# .env.local fica gitignored — nunca commitar credenciais reais.
#
# Em produção (Vercel), configure cada uma em Settings → Environment Variables.
# ============================================================


# ───────────── NextAuth (obrigatório) ─────────────
# Gerar com: openssl rand -base64 32  (ou no PowerShell:
#   [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32)) )
# Criptografa o cookie da sessão NextAuth.
AUTH_SECRET=

# URL canônica do site para o NextAuth.
# Dev:  http://localhost:3000
# Prod: https://seudominio.com.br
NEXTAUTH_URL=http://localhost:3000


# ───────────── Google OAuth ─────────────
# Console: https://console.cloud.google.com/apis/credentials
# Criar OAuth client → Web application → Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google
#   https://seudominio.com.br/api/auth/callback/google  (prod)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=


# ───────────── Microsoft Entra ID (OAuth) ─────────────
# Console: https://portal.azure.com → App registrations → New registration
# Tipo: "Accounts in any organizational directory and personal Microsoft accounts"
# Redirect URI (Web):
#   http://localhost:3000/api/auth/callback/microsoft-entra-id
#   https://seudominio.com.br/api/auth/callback/microsoft-entra-id  (prod)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=

# Tenant. Use "common" para aceitar contas pessoais (Hotmail/Outlook)
# E corporativas. Para restringir a um tenant específico, coloque o
# tenant ID (GUID).
AUTH_MICROSOFT_ENTRA_ID_TENANT=common

# Issuer URL completa. Construído automaticamente a partir do tenant,
# mas pode sobrescrever aqui se quiser fixar.
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0


# ───────────── Drupal (obrigatório) ─────────────
# URL do backend Drupal.
# Dev (DDEV): http://porto-das-oliveiras.ddev.site
# Prod:       https://api.porto.com.br
DRUPAL_BASE_URL=http://porto-das-oliveiras.ddev.site

# Segredo HS256 compartilhado com a Key "porto_frontend_jwt" no Drupal.
# Tem que ser EXATAMENTE o mesmo valor dos dois lados.
# Mínimo 32 chars (recomendado 48+).
# Gerar:
#   PowerShell: -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 48 | %{[char]$_})
#   Bash:       openssl rand -hex 32
# Configurar no Drupal:
#   ddev drush key:save porto_frontend_jwt "<segredo>" \
#     --label="Porto Frontend JWT" --key-type=authentication \
#     --key-provider=config --key-input=text_field -y
DRUPAL_JWT_SECRET=


# ───────────── Google Gemini (IA) ─────────────
# Necessário para /assistente. Gerar em:
#   https://aistudio.google.com/apikey
# Tier free é generoso para uso pessoal/MVP.
GEMINI_API_KEY=


# ───────────── Google Maps (mapa de lotes) ─────────────
# Necessário para o mapa interativo em /lotes.
# Cloud Console → APIs → "Maps JavaScript API" + "Geocoding API"
# Crie chave RESTRITA por domínio:
#   - localhost:3000/*
#   - seudominio.com.br/*
# NEXT_PUBLIC_ porque vai pro client (mapa renderiza no browser).
# Tier free: 28k loads/mês.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=


# ───────────── URL pública do site ─────────────
# Usado em:
#   - app/sitemap.ts (gera URLs absolutas)
#   - app/robots.ts (host + sitemap link)
#   - app/(public)/lotes/[slug]/page.tsx (canonical + og:url + JSON-LD)
# Dev:  http://localhost:3000
# Prod: https://seudominio.com.br  (SEM barra no final)
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ───────────── Observabilidade (opcional) ─────────────
# Nível mínimo de log emitido. Default: debug em dev, info em prod.
# Valores: debug | info | warn | error
LOG_LEVEL=

# SHA do commit em produção. Vercel preenche automaticamente via
# VERCEL_GIT_COMMIT_SHA — só defina aqui se rodar fora da Vercel.
# Exposto em /api/version. NEXT_PUBLIC_ porque pode ser exibido no client.
NEXT_PUBLIC_GIT_SHA=


# ───────────── WhatsApp (não-secret, pode ser literal) ─────────────
# O número aparece hardcoded no código atualmente. Quando quiser
# tornar configurável, adicionar essa var e ler no lib/whatsapp/format.ts.
# Formato internacional sem '+': 5577999999999
# NEXT_PUBLIC_WHATSAPP_NUMBER=5577999999999

# ---------- NextAuth ----------
# Gerar com: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ---------- Google OAuth ----------
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---------- Microsoft (Azure AD / personal Hotmail) ----------
# https://portal.azure.com — App registrations → "Personal Microsoft accounts only" ou "Any directory + personal"
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Use "common" para aceitar contas pessoais (hotmail/outlook) E corporativas
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# ---------- Drupal ----------
DRUPAL_BASE_URL=https://porto-das-oliveiras.ddev.site
# Segredo HS256 compartilhado com Drupal (módulo JWT). Mesmo valor em ambos os lados.
DRUPAL_JWT_SECRET=

# ---------- Gemini ----------
GEMINI_API_KEY=
